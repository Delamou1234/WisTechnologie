# PostgreSQL connection — this is the container started by "docker compose up -d db"
# (see docker-compose.yml). These same values provision the container's
# credentials AND are what the app uses to connect, so keep them in sync.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wistech
DB_USER=wistech
DB_PASSWORD=wistech

# Alternative to the DB_* vars above: a full connection string, e.g. for a
# managed/remote Postgres instance in production. Takes priority if set.
# DATABASE_URL=postgres://wistech:wistech@localhost:5432/wistech

# Mot de passe de connexion au panneau /admin, vérifié uniquement côté serveur
# (voir auth.ts). Changez-le avant de déployer en production.
ADMIN_PASSWORD=changeme

# Configuration SMTP pour l'envoi des emails de contact (formulaire /api/contact).
# Ces valeurs servent de config par défaut au premier démarrage (insérées une
# seule fois dans la table smtp_settings) ; elles peuvent ensuite être
# modifiées à chaud depuis le panneau Admin (Réglages > SMTP).

# Active ou non l'envoi d'emails de notification ("true" ou "false")
SMTP_ENABLED=false

# Hôte du serveur SMTP (ex: smtp.gmail.com, smtp-relay.brevo.com...)
SMTP_HOST=

# Port SMTP (587 pour STARTTLS, 465 pour SSL/TLS)
SMTP_PORT=587

# "true" pour une connexion SSL/TLS directe (port 465), "false" pour STARTTLS (port 587)
SMTP_SECURE=false

# Identifiant / adresse d'authentification SMTP
SMTP_USER=

# Mot de passe ou mot de passe d'application SMTP
SMTP_PASS=

# Adresse qui reçoit les messages du formulaire de contact
SMTP_TO=
